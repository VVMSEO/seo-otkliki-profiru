rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'messages', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.messages is list &&
             data.messages.size() <= 1000 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() &&
                      isValidId(chatId) &&
                      isValidChat(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;

      allow update: if isSignedIn() &&
                      isValidId(chatId) &&
                      existing().userId == request.auth.uid &&
                      isValidChat(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().userId == existing().userId &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'updatedAt']);

      allow delete: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;
    }
  }
}
